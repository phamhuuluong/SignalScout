# ATTRAOS Hub Server — Environment Variables
# Copy this file to .env and fill in your values

# ── Server ──────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ADMIN_TOKEN=change_this_to_a_strong_random_token

# ── Admin AI Keys (for broadcast & AI proxy) ─────────
ADMIN_GEMINI_KEY=your_gemini_api_key_here
ADMIN_DEEPSEEK_KEY=your_deepseek_api_key_here
ADMIN_OPENAI_KEY=your_openai_api_key_here   # optional

# ── Market Data ───────────────────────────────────────
TWELVEDATA_API_KEY=your_twelvedata_key_here  # free tier OK

# ── Scheduler Settings ───────────────────────────────
BROADCAST_ASSETS=XAUUSD,EURUSD,BTCUSD
AI_INTERVAL_MIN=15          # run AI broadcast every N minutes
NEWS_INTERVAL_MIN=30        # run news summary every N minutes
MAX_ANALYZE_PER_HOUR=20     # per device rate limit

# ── Firebase (for push notifications) ─────────────────
# FIREBASE_CREDENTIALS_JSON=/path/to/serviceAccount.json

# ── Rate Limiting ─────────────────────────────────────
# In production, use Redis instead of in-memory
# REDIS_URL=redis://localhost:6379
